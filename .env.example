# =============================================================================
# Argus by Perciqa — Environment Variables
# Copy this file to .env and fill in your values. NEVER commit .env.
# =============================================================================

# ---- Server ----
ARGUS_HOST=0.0.0.0
ARGUS_PORT=8000
ARGUS_DB_PATH=data/argus.db

# ---- Eval Engine ----
# LLM judge for automated trace evaluation.
# Default: DeepSeek V4 Flash (serverless, $0.14/M input · $0.28/M output · 1M context)
# ~$0.00042 per eval — effectively unlimited on a $65 budget.
# Sample rate: 0.0 = never eval, 1.0 = eval every trace
EVAL_SAMPLE_RATE=1.0
JUDGE_MODEL=accounts/fireworks/models/deepseek-v4-flash
JUDGE_BASE_URL=https://api.fireworks.ai/inference/v1

# ---- Fireworks AI (cloud inference) ----
FIREWORKS_API_KEY=fw_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# ---- AMD Developer Cloud (local inference) ----
AMD_CLOUD_BASE_URL=http://localhost:8080/v1
AMD_CLOUD_API_KEY=

# ---- Dashboard ----
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ---- Auth ----
# API key for SDK → Server trace ingestion. Leave empty for local dev (auth disabled).
ARGUS_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub OAuth for dashboard login
# Create an OAuth app at https://github.com/settings/developers
# Homepage URL: http://localhost:3000
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=Ov23li...
AUTH_GITHUB_SECRET=...
# Generate with: openssl rand -base64 32
AUTH_SECRET=...

# CORS origins for the server (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000
